{
  "$comment": "Ground-truth FSM for VigilClock. Evaluator-only; not consumed by the running app.",
  "app_id": "com.vigil.clock",
  "model": "M_A = <S, s0, Sigma, delta, Gamma, I, rho>",
  "transition_kinds": ["nav", "tick_done", "system_back", "terminal"],
  "initial_state": "alarm_list",
  "terminal_states": [],
  "states": [
    {"id": "alarm_list",        "screen_marker": "screen:alarm_list"},
    {"id": "alarm_edit",        "screen_marker": "screen:alarm_edit"},
    {"id": "timer_setup",       "screen_marker": "screen:timer_setup"},
    {"id": "timer_running",     "screen_marker": "screen:timer_running",
     "volatile_readout": "timer.remaining"},
    {"id": "timer_paused",      "screen_marker": "screen:timer_paused",
     "volatile_readout": "timer.remaining"},
    {"id": "timer_done",        "screen_marker": "screen:timer_done",
     "volatile_readout": "timer.remaining"},
    {"id": "stopwatch_idle",    "screen_marker": "screen:stopwatch_idle"},
    {"id": "stopwatch_running", "screen_marker": "screen:stopwatch_running",
     "volatile_readout": "stopwatch.elapsed"},
    {"id": "stopwatch_paused",  "screen_marker": "screen:stopwatch_paused",
     "volatile_readout": "stopwatch.elapsed"},
    {"id": "settings",          "screen_marker": "screen:settings"}
  ],
  "templates": {
    "alarms": ["a_morning", "a_lunch", "a_evening"],
    "timer_durations": ["d_1m", "d_5m", "d_10m", "d_25m"]
  },
  "actions": [
    {"name": "alarm.toggle.<alarm_id>", "type": "click", "query": "alarm.toggle.<alarm_id>",
     "template_params": ["alarm_id"]},
    {"name": "alarm.edit.<alarm_id>",   "type": "click", "query": "alarm.edit.<alarm_id>",
     "template_params": ["alarm_id"]},
    {"name": "alarm_edit.hour.increment",   "type": "click", "query": "alarm_edit.hour.increment"},
    {"name": "alarm_edit.hour.decrement",   "type": "click", "query": "alarm_edit.hour.decrement"},
    {"name": "alarm_edit.minute.increment", "type": "click", "query": "alarm_edit.minute.increment"},
    {"name": "alarm_edit.minute.decrement", "type": "click", "query": "alarm_edit.minute.decrement"},
    {"name": "alarm_edit.save",   "type": "click", "query": "alarm_edit.save"},
    {"name": "alarm_edit.cancel", "type": "click", "query": "alarm_edit.cancel"},
    {"name": "timer.duration.<duration_id>", "type": "click", "query": "timer.duration.<duration_id>",
     "template_params": ["duration_id"]},
    {"name": "timer.start",              "type": "click", "query": "timer.start"},
    {"name": "timer.pause",              "type": "click", "query": "timer.pause"},
    {"name": "timer.resume",             "type": "click", "query": "timer.resume"},
    {"name": "timer.reset",              "type": "click", "query": "timer.reset"},
    {"name": "timer.fast_forward_done",  "type": "click", "query": "timer.fast_forward_done"},
    {"name": "stopwatch.start",  "type": "click", "query": "stopwatch.start"},
    {"name": "stopwatch.pause",  "type": "click", "query": "stopwatch.pause"},
    {"name": "stopwatch.resume", "type": "click", "query": "stopwatch.resume"},
    {"name": "stopwatch.lap",    "type": "click", "query": "stopwatch.lap"},
    {"name": "stopwatch.reset",  "type": "click", "query": "stopwatch.reset"},
    {"name": "settings.reset_demo", "type": "click", "query": "settings.reset_demo"},
    {"name": "nav.open_alarms",     "type": "click", "query": "nav.open_alarms",     "global_nav": true},
    {"name": "nav.open_timer",      "type": "click", "query": "nav.open_timer",      "global_nav": true},
    {"name": "nav.open_stopwatch",  "type": "click", "query": "nav.open_stopwatch",  "global_nav": true},
    {"name": "nav.open_settings",   "type": "click", "query": "nav.open_settings",   "global_nav": true},
    {"name": "system.back",         "type": "system_back", "query": "system.back"}
  ],
  "global_navigation": {
    "$comment": "Bottom nav is visible on every state. nav.open_timer routes to whichever of timer_setup/running/paused/done is current; nav.open_stopwatch likewise. This is encoded as multiple alternative transitions guarded by the current screen.",
    "visible_on": ["alarm_list", "alarm_edit", "timer_setup", "timer_running", "timer_paused", "timer_done", "stopwatch_idle", "stopwatch_running", "stopwatch_paused", "settings"],
    "actions": [
      {"action": "nav.open_alarms",    "to": "alarm_list",        "kind": "nav"},
      {"action": "nav.open_timer",     "to": "timer_setup",       "kind": "nav",
        "guard": "current_screen not in {timer_running, timer_paused, timer_done}"},
      {"action": "nav.open_timer",     "to": "timer_running",     "kind": "nav",
        "guard": "current_screen == timer_running"},
      {"action": "nav.open_timer",     "to": "timer_paused",      "kind": "nav",
        "guard": "current_screen == timer_paused"},
      {"action": "nav.open_timer",     "to": "timer_done",        "kind": "nav",
        "guard": "current_screen == timer_done"},
      {"action": "nav.open_stopwatch", "to": "stopwatch_idle",    "kind": "nav",
        "guard": "current_screen not in {stopwatch_running, stopwatch_paused}"},
      {"action": "nav.open_stopwatch", "to": "stopwatch_running", "kind": "nav",
        "guard": "current_screen == stopwatch_running"},
      {"action": "nav.open_stopwatch", "to": "stopwatch_paused",  "kind": "nav",
        "guard": "current_screen == stopwatch_paused"},
      {"action": "nav.open_settings",  "to": "settings",          "kind": "nav"}
    ]
  },
  "transitions": [
    {"from": "alarm_list", "action": "alarm.toggle.<alarm_id>", "to": "alarm_list", "kind": "nav",
      "binds": {"alarm_id": "<alarm_id>"}},
    {"from": "alarm_list", "action": "alarm.edit.<alarm_id>",   "to": "alarm_edit", "kind": "nav",
      "binds": {"alarm_id": "<alarm_id>"}},

    {"from": "alarm_edit", "action": "alarm_edit.hour.increment",   "to": "alarm_edit", "kind": "nav"},
    {"from": "alarm_edit", "action": "alarm_edit.hour.decrement",   "to": "alarm_edit", "kind": "nav"},
    {"from": "alarm_edit", "action": "alarm_edit.minute.increment", "to": "alarm_edit", "kind": "nav"},
    {"from": "alarm_edit", "action": "alarm_edit.minute.decrement", "to": "alarm_edit", "kind": "nav"},
    {"from": "alarm_edit", "action": "alarm_edit.save",             "to": "alarm_list", "kind": "nav"},
    {"from": "alarm_edit", "action": "alarm_edit.cancel",           "to": "alarm_list", "kind": "nav"},
    {"from": "alarm_edit", "action": "system.back",                 "to": "alarm_list", "kind": "system_back"},

    {"from": "timer_setup", "action": "timer.duration.<duration_id>", "to": "timer_setup", "kind": "nav",
      "binds": {"duration_id": "<duration_id>"}},
    {"from": "timer_setup", "action": "timer.start", "to": "timer_running", "kind": "nav",
      "guard": "timer_selected_duration_id != null"},

    {"from": "timer_running", "action": "timer.pause",             "to": "timer_paused", "kind": "nav"},
    {"from": "timer_running", "action": "timer.reset",             "to": "timer_setup",  "kind": "nav"},
    {"from": "timer_running", "action": "timer.fast_forward_done", "to": "timer_done",   "kind": "nav"},
    {"from": "timer_running", "action": "$tick_elapsed_eq_duration","to": "timer_done",  "kind": "tick_done",
      "$comment": "Implicit transition: tick advances timer.elapsed_ms to timer.duration_ms."},

    {"from": "timer_paused", "action": "timer.resume",             "to": "timer_running", "kind": "nav"},
    {"from": "timer_paused", "action": "timer.reset",              "to": "timer_setup",   "kind": "nav"},
    {"from": "timer_paused", "action": "timer.fast_forward_done",  "to": "timer_done",    "kind": "nav"},

    {"from": "timer_done", "action": "timer.reset", "to": "timer_setup", "kind": "nav"},

    {"from": "stopwatch_idle",    "action": "stopwatch.start",  "to": "stopwatch_running", "kind": "nav"},
    {"from": "stopwatch_running", "action": "stopwatch.pause",  "to": "stopwatch_paused",  "kind": "nav"},
    {"from": "stopwatch_running", "action": "stopwatch.lap",    "to": "stopwatch_running", "kind": "nav"},
    {"from": "stopwatch_running", "action": "stopwatch.reset",  "to": "stopwatch_idle",    "kind": "nav"},
    {"from": "stopwatch_paused",  "action": "stopwatch.resume", "to": "stopwatch_running", "kind": "nav"},
    {"from": "stopwatch_paused",  "action": "stopwatch.reset",  "to": "stopwatch_idle",    "kind": "nav"},

    {"from": "settings", "action": "settings.reset_demo", "to": "alarm_list", "kind": "nav"}
  ],
  "system_back_routes": {
    "$comment": "Only alarm_edit consumes back; every other top-level tab returns false so the activity exits.",
    "alarm_edit": "alarm_list",
    "alarm_list": null,
    "timer_setup": null,
    "timer_running": null,
    "timer_paused": null,
    "timer_done": null,
    "stopwatch_idle": null,
    "stopwatch_running": null,
    "stopwatch_paused": null,
    "settings": null
  }
}
