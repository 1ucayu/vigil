# M3A (AndroidWorld) — environment
# Copy to .env and source before running minimal_task_runner.py.
# Vigil's Claude-Code integration also reads these automatically.
#
# Default: route to local OpenAI-compatible proxy at http://localhost:4141/v1
# (Vigil convention — see configs/default.yaml in the Vigil root).
OPENAI_API_KEY=dummy_key
OPENAI_BASE_URL=http://localhost:4141/v1
OPENAI_MODEL=claude-sonnet-4.6

# --- Uncomment to use a real OpenAI key instead ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4-turbo-2024-04-09

# Optional: Google model variant (gemini)
# GCP_API_KEY=
