# Mobile-Agent-v2 — environment
# Copy to .env and source before running run.py.
#
# Default: route planner LLM to Vigil's local OpenAI-compatible proxy.
# Caption model (Qwen-VL) has no local proxy option here — leave the Qwen API
# key blank if you only want to test the planner path.

ADB_PATH=/opt/homebrew/bin/adb
MAV2_INSTRUCTION=Open the Settings app and enable Wi-Fi

# Planner LLM (GPT-4o role)
OPENAI_API_KEY=dummy_key
OPENAI_BASE_URL=http://localhost:4141/v1

# Caption backend
MAV2_CAPTION_METHOD=api
MAV2_CAPTION_MODEL=qwen-vl-plus
# Your DashScope key for Qwen-VL captioning. Leave empty if you will swap in
# a local caption model (MAV2_CAPTION_METHOD=local) — requires ~15GB of weights.
DASHSCOPE_API_KEY=

# --- Uncomment for real OpenAI endpoint ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
